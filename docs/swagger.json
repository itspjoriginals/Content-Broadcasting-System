          }
        }
      }
    },
    "/content/live/{teacherId}": {
      "get": {
        "tags": [
          "Broadcast (Public)"
        ],
        "summary": "Get all live content for a teacher",
        "description": "**Public endpoint — no authentication required.**\n\nReturns all currently active content for a teacher, grouped by subject.\n\n### Scheduling / Rotation Logic\nContent is active when ALL conditions are met:\n1. Status is `approved`\n2. Current time is within `start_time` → `end_time` window\n3. It is this item's turn in the rotation cycle\n\n**Rotation algorithm** (stateless, deterministic):\n- `anchor` = earliest `start_time` among active items in subject group\n- `cycle` = sum of all `rotation_duration` values in the group\n- `elapsed` = `(now - anchor) mod cycle`\n- Walk items in `rotation_order` to find which window `elapsed` falls in\n\n### Edge Cases → All return `\"No content available\"`\n- Unknown teacher ID\n- No approved content\n- Approved but outside time window\n- Approved + in-window but another item's rotation slot\n",
        "parameters": [
          {
            "name": "teacherId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Teacher UUID obtained from /users/teachers or auth login",
            "example": "d1a2b3c4-e5f6-7890-abcd-ef1234567890"
          }
        ],
        "responses": {
          "200": {
            "description": "Live content per subject, or no content available",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/SuccessResponse"
                    },
                    {
                      "type": "object",
                      "properties": {
                        "data": {
                          "nullable": true,
                          "type": "object",
                          "properties": {
                            "teacher": {
                              "type": "object",
                              "properties": {
                                "id": {
                                  "type": "string",
                                  "format": "uuid"
                                },
                                "name": {
                                  "type": "string"
                                }
                              }
                            },
                            "live": {
                              "type": "object",
                              "additionalProperties": {
                                "$ref": "#/components/schemas/LiveContentItem"
                              },
                              "description": "Keys are subject names"
                            }
                          }
                        }
                      }
                    }
                  ]
                },
                "examples": {
                  "live_content": {
                    "summary": "Active content returned",
                    "value": {
                      "success": true,
                      "message": "Success",
                      "data": {
                        "teacher": {
                          "id": "d1a2b3c4-e5f6-7890-abcd-ef1234567890",
                          "name": "Alice Teacher"
                        },
                        "live": {
                          "maths": {
                            "id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
                            "title": "Chapter 3 Quiz",
                            "subject": "maths",
                            "file_url": "http://localhost:3000/uploads/abc123.jpg",
                            "file_type": "image/jpeg",
                            "original_name": "quiz-ch3.jpg",
                            "rotation_order": 0,
                            "slot_duration_minutes": 5,
                            "active_window": {
                              "start": "2025-06-01T09:00:00.000Z",
                              "end": "2025-12-31T18:00:00.000Z"
                            }
                          },
                          "science": {
                            "id": "b2c3d4e5-f6a7-8901-bcde-f12345678901",
                            "title": "Plant Cell Diagram",
                            "subject": "science",
                            "file_url": "http://localhost:3000/uploads/def456.png",
                            "file_type": "image/png",
                            "original_name": "plant-cell.png",
                            "rotation_order": 1,
                            "slot_duration_minutes": 5,
                            "active_window": {
                              "start": "2025-06-01T09:00:00.000Z",
                              "end": "2025-12-31T18:00:00.000Z"
                            }
                          }
                        }
                      }
                    }
                  },
                  "no_content": {
                    "summary": "No content available",
                    "value": {
                      "success": true,
                      "message": "No content available",
                      "data": null
                    }
                  }
                }
              }
            }
          },
          "429": {
            "$ref": "#/components/responses/TooManyRequests"
          }
        }
      }
    },
    "/content/live/{teacherId}/{subject}": {
      "get": {
        "tags": [
          "Broadcast (Public)"
        ],
        "summary": "Get live content for specific subject",
        "description": "**Public endpoint — no authentication required.**\n\nReturns the single currently-active content item for a specific subject under a teacher.\nReturns `\"No content available\"` for invalid subject names (not a 404).\n",
        "parameters": [
          {
            "name": "teacherId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "example": "d1a2b3c4-e5f6-7890-abcd-ef1234567890"
          },
          {
            "name": "subject",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Subject name (case-insensitive)",
            "example": "maths"
          }
        ],
        "responses": {
          "200": {
            "description": "Active content for subject or no content",
            "content": {
              "application/json": {
                "examples": {
                  "live": {
                    "summary": "Active content",
                    "value": {
                      "success": true,
                      "message": "Success",
                      "data": {
                        "teacher": {
                          "id": "d1a2b3c4-e5f6-7890-abcd-ef1234567890",
                          "name": "Alice Teacher"
                        },
                        "subject": "maths",
                        "content": {
                          "id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
                          "title": "Chapter 3 Quiz",
                          "subject": "maths",
                          "file_url": "http://localhost:3000/uploads/abc123.jpg",
                          "file_type": "image/jpeg",
                          "slot_duration_minutes": 5,
                          "active_window": {
                            "start": "2025-06-01T09:00:00.000Z",
                            "end": "2025-12-31T18:00:00.000Z"
                          }
                        }
                      }
                    }
                  },
                  "no_content": {
                    "summary": "No content available",
                    "value": {
                      "success": true,
                      "message": "No content available",
                      "data": null
                    }
                  }
                }
              }
            }
          },
          "429": {
            "$ref": "#/components/responses/TooManyRequests"
          }
        }
      }
    },
